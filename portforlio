<div class="row g-4 portfolio-container" id="portfolio-container">
  <!-- Projects will be dynamically injected here -->
</div>

<script>
  const projects = [
    {
      title: "Brain Tumor Detection",
      description: "Deep Learning & Tensor Methods",
      image: "assets/img/project1.jpg",
      detailImage: "assets/img/tensor.jpg",
      link: "portfolio-details.html#brain-tumor"
    },
    {
      title: "Bank Customer Churn",
      description: "Predictive Modeling",
      image: "assets/img/project2.jpg",
      detailImage: "assets/img/churn.jpg",
      link: "portfolio-details.html#bank-churn"
    },
    {
      title: "Geophysical Inversion",
      description: "Gaussian Processes Research",
      image: "assets/img/project3.jpg",
      detailImage: "assets/img/geophysical.png",
      link: "portfolio-details.html#geophysical"
    }
  ];

  const container = document.getElementById('portfolio-container');

  projects.forEach(project => {
    container.innerHTML += `
      <div class="col-lg-4 col-md-6 portfolio-item">
        <div class="portfolio-wrap">
          <img src="${project.image}" class="img-fluid" alt="${project.title}">
          <div class="portfolio-info">
            <h4>${project.title}</h4>
            <p>${project.description}</p>
            <a href="${project.detailImage}" class="glightbox" title="${project.title}"><i class="bi bi-plus"></i></a>
            <a href="${project.link}" class="btn btn-sm btn-primary mt-2">View Details</a>
          </div>
        </div>
      </div>
    `;
  });
</script>
